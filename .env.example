# Required
CHZZK_CLIENT_ID=""
CHZZK_CLIENT_SECRET=""
CHZZK_REDIRECT_URI="http://localhost:8080/callback"

# Required because the token API documentation provides paths only:
# POST /auth/v1/token
# POST /auth/v1/token/revoke
CHZZK_API_BASE_URL="https://openapi.chzzk.naver.com"

# Optional
CHZZK_AUTH_HOST="https://chzzk.naver.com"
CHZZK_TOKEN_FILE=".chzzk_tokens.json"
CHZZK_STATE_FILE=".chzzk_state"
CHZZK_SERVER_HOST="127.0.0.1"
CHZZK_SERVER_PORT="8080"

# Optional command values
CHZZK_AUTH_CODE=""
CHZZK_AUTH_STATE=""
CHZZK_ACCESS_TOKEN=""
CHZZK_REFRESH_TOKEN=""
CHZZK_TOKEN_TYPE_HINT="access_token"
